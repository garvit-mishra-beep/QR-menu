# ==========================================
# Frontend (Next.js) Git Ignores
# ==========================================
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.env
frontend/.env.local
frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/.pnpm-debug.log*

# ==========================================
# Backend (FastAPI / Python) Git Ignores
# ==========================================
backend/__pycache__/
backend/*.py[cod]
backend/*$py.class
backend/.pytest_cache/
backend/venv/
backend/env/
backend/ENV/
backend/sqlite.db
backend/*.db
backend/.env

# ==========================================
